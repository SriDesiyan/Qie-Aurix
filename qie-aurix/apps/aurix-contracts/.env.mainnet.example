# ─────────────────────────────────────────────────────────────────────────────
# QIE Aurix — Production Mainnet Deployment Environment Variables
# Copy to .env in this directory to deploy to production mainnet.
# ─────────────────────────────────────────────────────────────────────────────

# Production QIE Blockchain Mainnet RPC
QIE_RPC_URL=https://rpc1mainnet.qie.digital/

# Private key for the deploying account (Do not commit real keys!)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRODUCTION_DEPLOYER_PRIVATE_KEY_HERE

# Registered smart contract addresses on QIE Mainnet
QIE_PASS_ADDRESS=REQUIRES_OFFICIAL_ADDRESS
QUSDC_ADDRESS=0x3F43DA82eC9A4f5285F10FaF1F26EcA7319E5DA5
QIE_DOMAINS_ADDRESS=REQUIRES_OFFICIAL_ADDRESS
