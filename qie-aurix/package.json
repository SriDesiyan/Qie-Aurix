{
  "name": "qie-aurix",
  "version": "1.0.0",
  "private": true,
  "description": "QIE Aurix — AI-Powered Decentralized Financial Resilience Guardian",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/aurix-web",
    "dev:oracle": "npm run dev --workspace=apps/aurix-oracle",
    "build": "npm run build --workspaces --if-present",
    "compile:contracts": "npm run compile --workspace=apps/aurix-contracts",
    "test:contracts": "npm run test --workspace=apps/aurix-contracts",
    "clean": "npm run clean --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
